'''
class Node:
    def __init__(self, data): 
        self.data = data
        self.next = None
'''

class Solution:
    def lengthOfLoop(self, head):
        slow,fast=head,head
        while fast!=None and fast.next!=None:
            slow=slow.next
            fast=fast.next.next
            
            if slow==fast:
                break # cycle Found
        if fast==None or fast.next==None :
            return 0
        n1=slow
        n2=head
        while n1!=n2:
            n1=n1.next
            n2=n2.next
            
        length=1
        curr=n1.next
        while curr!=n1:
            length+=1
            curr=curr.next
        return length
        
